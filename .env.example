NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (do not expose client-side)
SUPABASE_SERVICE_ROLE_KEY=

# Used to generate absolute QR URLs (decide real domain before Phase 4)
APP_BASE_URL=http://localhost:3000

# Phase 4 (printing)
PRINT_BRIDGE_URL=
PRINT_BRIDGE_SECRET=

# Phase 5 (Mailchimp)
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_AUDIENCE_ID=
# Set to true to queue events without calling Mailchimp API (local dev default when keys missing)
MAILCHIMP_OUTBOX_ONLY=

# Shopify pricing sync (HIL-52) — Dev Dashboard app credentials
SHOPIFY_STORE_DOMAIN=hildas-houseplants.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Daily cron: GET /api/cron/shopify-pricing with Authorization: Bearer <secret>
CRON_SECRET=

